NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Required only when running the read-only staging smoke test.
STAGING_SMOKE_CONFIRM=read-only
# Optional: where staging smoke writes its local success evidence.
STAGING_SMOKE_REPORT_PATH=artifacts/staging-smoke/latest.json
# Optional: override for self-evaluation when recording an externally verified smoke pass.
STAGING_SMOKE_PASSED_AT=

# Optional: enables LLM extraction. Leave unset for local UI and rule-based tests.
OPENAI_API_KEY=
OPENAI_EXTRACTION_MODEL=gpt-5.4-mini

# Optional official / semi-official data source credentials.
GBIZINFO_API_TOKEN=
GBIZINFO_API_BASE_URL=https://info.gbiz.go.jp/hojin/v1/hojin
EDINET_API_KEY=
EDINET_API_BASE_URL=https://api.edinet-fsa.go.jp/api/v2/documents.json
NTA_SOURCE_URL=https://www.houjin-bangou.nta.go.jp/download/

# Optional external search abstraction. Must return JSON: { "results": [{ "title", "url", "snippet" }] }
SEARCH_API_ENDPOINT=
SEARCH_API_KEY=

# Conservative crawler defaults.
CRAWLER_USER_AGENT=JapanCompanyCollector/0.1
CRAWLER_MAX_DEPTH=2
CRAWLER_MAX_PAGES=20
CRAWLER_MIN_DOMAIN_DELAY_MS=3000
